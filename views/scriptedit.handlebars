<html>
<head>
    <script type="text/javascript" src="scripts/common-0.0.1.js"></script>
</head>
<style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #e0e0e0; background-color: #036; margin: 0; padding: 0;
    }
    #scriptTaskScriptEdit { padding: 16px; }
    .editRow { display: flex; gap: 12px; align-items: center; margin-bottom: 10px; flex-wrap: wrap; }
    .editRow label { font-size: 12px; font-weight: 600; white-space: nowrap; }
    .editRow input[type="text"], .editRow select {
      padding: 5px 8px; font-size: 13px; border: 1px solid #567; border-radius: 4px;
      background: #024; color: #e0e0e0;
    }
    #scriptName { width: 300px; }
    #scriptDescription { width: 100%; max-width: 600px; }
    #scriptContent { width: 100%; height: calc(100vh - 200px); font-family: monospace; font-size: 13px;
      background: #012; color: #e0e0e0; border: 1px solid #567; border-radius: 4px; padding: 8px; }
    .ebtn {
      padding: 6px 16px; border: 1px solid #567; border-radius: 4px; background: #036;
      color: #fff; font-weight: 600; cursor: pointer; font-size: 13px;
    }
    .ebtn:hover { background: #048; }
    .ebtn.primary { background: #2563eb; border-color: #2563eb; }
    .ebtn.primary:hover { background: #1d4ed8; }
    /* Tag chips */
    .tagChips { display: flex; flex-wrap: wrap; gap: 4px; align-items: center; }
    .tagChip {
      display: inline-flex; align-items: center; gap: 3px;
      padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600;
      background: #1a4a7a; color: #93c5fd; cursor: default;
    }
    .tagChip .tagX {
      cursor: pointer; font-size: 13px; margin-left: 2px; color: #6b9fd4;
    }
    .tagChip .tagX:hover { color: #ff6b6b; }
    #tagInput { width: 120px; }
</style>
<body onload="doOnLoad();">
<div id="scriptTaskScriptEdit">
  <div class="editRow">
    <label>Name:</label> <input type="text" value="" id="scriptName"/>
    <label>Category:</label> <select id="scriptCategory"><option value="">-- None --</option></select>
  </div>
  <div class="editRow">
    <label>Description:</label> <input type="text" value="" id="scriptDescription" placeholder="One-line summary of what this script does"/>
  </div>
  <div class="editRow">
    <label>Tags:</label>
    <div class="tagChips" id="tagChipsContainer"></div>
    <select id="tagInput" onchange="addTagFromSelect(this);"><option value="">+ Add tag...</option></select>
  </div>
  <div class="editRow">
    <button class="ebtn primary" onclick="goSave();">Save</button>
    <button class="ebtn" onclick="goClose();">Close</button>
  </div>
  <textarea id="scriptContent"></textarea>
</div>
</body>
<script type="text/javascript">
var scriptData = {{{scriptData}}};
var selectedTags = [];

function doOnLoad() {
    Q('scriptContent').value = scriptData.content;
    Q('scriptName').value = scriptData.name;
    Q('scriptDescription').value = scriptData.description || '';
    selectedTags = (scriptData.tags && Array.isArray(scriptData.tags)) ? scriptData.tags.slice() : [];

    // Load categories and tags from parent window's cached meta
    try {
        var meta = window.opener._innovoMeta || { categories: [], tags: [] };
        var catSel = Q('scriptCategory');
        meta.categories.forEach(function(c) {
            var opt = document.createElement('option');
            opt.value = c.name; opt.textContent = c.name;
            if (scriptData.category === c.name) opt.selected = true;
            catSel.appendChild(opt);
        });
        var tagSel = Q('tagInput');
        meta.tags.forEach(function(t) {
            var opt = document.createElement('option');
            opt.value = t.name; opt.textContent = t.name;
            tagSel.appendChild(opt);
        });
    } catch(e) {}

    if (scriptData.category) Q('scriptCategory').value = scriptData.category;
    renderTags();
}

function renderTags() {
    var container = Q('tagChipsContainer');
    container.innerHTML = '';
    selectedTags.forEach(function(t, idx) {
        var chip = document.createElement('span');
        chip.className = 'tagChip';
        chip.innerHTML = t + '<span class="tagX" onclick="removeTag(' + idx + ');">&times;</span>';
        container.appendChild(chip);
    });
}

function addTagFromSelect(sel) {
    var val = sel.value;
    if (!val) return;
    if (selectedTags.indexOf(val) === -1) {
        selectedTags.push(val);
        renderTags();
    }
    sel.value = '';
}

function removeTag(idx) {
    selectedTags.splice(idx, 1);
    renderTags();
}

function goSave() {
    scriptData.content = Q('scriptContent').value;
    scriptData.name = Q('scriptName').value;
    scriptData.description = Q('scriptDescription').value;
    scriptData.category = Q('scriptCategory').value;
    scriptData.tags = selectedTags;
    window.opener.callback(scriptData);
}

function goClose() {
    window.close();
}
</script>
</html>
