</body>
<script type="text/javascript">
  // Inherit dark/night mode from parent MeshCentral
  try {
    if (parent.document.body.classList.contains("night") ||
        parent.document.documentElement.getAttribute("data-bs-theme") === "dark") {
      document.body.classList.add("night");
    }
  } catch(e) {}
var scriptTree = {{{scriptTree}}};
var elementDragged = false;
var dragCounter = 0;
var draggedId = null;
var nodesObj = {};
var variables = [];
var varScopes = { global: 'Global', script: 'Script', mesh: 'Mesh', node: 'Node' };

function escHtml(s) {
    if (!s) return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function filterScriptTree() {
    var query = (Q('scriptSearch').value || '').toLowerCase();
    var cat = Q('categoryFilter').value;
    var scripts = document.querySelectorAll('.liscript');
    var visiblePaths = {};
    scripts.forEach(function(el) {
        var name = (el.querySelector('.fname') || {}).textContent || '';
        var elCat = el.getAttribute('x-data-category') || '';
        var elDesc = el.getAttribute('x-data-description') || '';
        var matchSearch = !query || name.toLowerCase().indexOf(query) !== -1 || elDesc.toLowerCase().indexOf(query) !== -1;
        var matchCat = !cat || elCat === cat;
        var show = matchSearch && matchCat;
        el.style.display = show ? '' : 'none';
        if (el.nextElementSibling && el.nextElementSibling.classList.contains('scriptDesc')) {
            el.nextElementSibling.style.display = show ? '' : 'none';
        }
        if (show) {
            var path = el.getAttribute('x-data-path');
            visiblePaths[path] = true;
            var parts = path.split('/');
            for (var i = 1; i <= parts.length; i++) {
                visiblePaths[parts.slice(0, i).join('/')] = true;
            }
        }
    });
    var folders = document.querySelectorAll('.lifolder');
    folders.forEach(function(el) {
        var fpath = el.getAttribute('x-data-path');
        el.style.display = visiblePaths[fpath] ? '' : 'none';
    });
}
function onlyUnique(value, index, self) {
    return self.indexOf(value) === index;
}
function resizeIframe() {
    document.body.style.height = 0;
    parent.pluginHandler.innovoscripttask.resizeContent();
}
function updateScriptInfoCard(el) {
    var card = Q('scriptInfoCard');
    if (!el || el.getAttribute('x-data-id') === el.getAttribute('x-data-folder')) {
        card.style.display = 'none'; return;
    }
    var name = (el.querySelector('.fname') || {}).textContent || '';
    var ftype = el.querySelector('.ftype') ? el.querySelector('.ftype').textContent : '';
    var cat = el.getAttribute('x-data-category') || '';
    var desc = el.getAttribute('x-data-description') || '';
    Q('siName').textContent = name;
    Q('siType').textContent = ftype;
    var catEl = Q('siCat');
    if (cat) { catEl.textContent = cat; catEl.setAttribute('data-cat', cat); catEl.style.display = ''; }
    else { catEl.style.display = 'none'; }
    Q('siDesc').textContent = desc || 'No description';
    card.style.display = '';
}
// Parse raw tags into structured info
function parseTags(tags) {
    var info = { deviceType: '', dp: '', ha: '', patch: '', py: '', schema: '', ip: '', mac: '', raw: tags || [] };
    if (!tags || !tags.length) return info;
    tags.forEach(function(t) {
        if (/^(MagicCube|MagicPro|MC-|MCPlaya)/i.test(t)) info.deviceType = t;
        else if (/^dp-\s/i.test(t)) info.dp = t.replace(/^dp-\s*/i, '');
        else if (/^ha-\s/i.test(t)) info.ha = t.replace(/^ha-\s*/i, '');
        else if (/^p-\s/i.test(t)) info.patch = t.replace(/^p-\s*/i, '');
        else if (/^py-\s/i.test(t)) info.py = t.replace(/^py-\s*/i, '');
        else if (/^s-\s/i.test(t)) info.schema = t.replace(/^s-\s*/i, '');
        else if (/^\d+\.\d+\.\d+\.\d+$/.test(t)) info.ip = t;
        else if (/^[0-9a-f]{2}:[0-9a-f]{2}:/i.test(t)) info.mac = t;
    });
    return info;
}

function updateNodesTable() {
  var nodeList = Q('arNodeList'); nodeList.innerHTML = '';
  var meshList = Q('arMeshList'); meshList.innerHTML = '';
  var typeList = Q('arTypeList'); typeList.innerHTML = '';
  var versionList = Q('arVersionList'); versionList.innerHTML = '';
  var hiddenTbl = Q('mRunTbl'); hiddenTbl.innerHTML = '';
  var deviceTypes = {}, dpVersions = {}, haVersions = {}, patchLevels = {}, pyVersions = {}, schemaVersions = {};

  parent.nodes.forEach(function(i) {
      var item = {...i, ...{}};
      if (item.mtype == 2) {
          item.meshName = parent.meshes[item['meshid']] ? parent.meshes[item['meshid']].name : '';
          var checked = (item._id == parent.currentNode._id) ? 'checked' : '';
          var ti = parseTags(item.tags);
          item._parsedTags = ti;
          nodesObj[i._id] = item;

          // Build info badges
          var badges = '';
          if (ti.deviceType) badges += '<span class="arTagBadge">' + escHtml(ti.deviceType.replace(/^MagicCube/,'')) + '</span>';
          if (ti.dp) badges += '<span class="arTagBadge">dp ' + escHtml(ti.dp) + '</span>';
          if (ti.ha) badges += '<span class="arTagBadge">ha ' + escHtml(ti.ha) + '</span>';
          if (ti.patch) badges += '<span class="arTagBadge">p' + escHtml(ti.patch) + '</span>';
          if (ti.ip) badges += '<span class="arNodeInfo">' + escHtml(ti.ip) + '</span>';

          // Node checkbox
          var lbl = document.createElement('label');
          lbl.className = 'arNodeItem';
          lbl.setAttribute('data-name', item.name.toLowerCase());
          lbl.setAttribute('data-mesh', item.meshid);
          lbl.setAttribute('data-type', ti.deviceType);
          lbl.setAttribute('data-ip', ti.ip);
          lbl.setAttribute('data-dp', ti.dp);
          lbl.setAttribute('data-ha', ti.ha);
          lbl.setAttribute('data-patch', ti.patch);
          lbl.setAttribute('data-py', ti.py);
          lbl.setAttribute('data-schema', ti.schema);
          lbl.innerHTML = '<input type="checkbox" ' + checked + ' name="runOn[]" value="' + item._id + '" onchange="updateSelectedCount();"> ' + escHtml(item.name) + badges;
          nodeList.appendChild(lbl);

          // Hidden row for backwards compat
          hiddenTbl.insertAdjacentHTML('beforeend', '<tr><td><input type="checkbox" ' + checked + ' name="runOn[]" value="' + item._id + '"></td></tr>');

          // Collect counts
          if (ti.deviceType) deviceTypes[ti.deviceType] = (deviceTypes[ti.deviceType] || 0) + 1;
          if (ti.dp) dpVersions[ti.dp] = (dpVersions[ti.dp] || 0) + 1;
          if (ti.ha) haVersions[ti.ha] = (haVersions[ti.ha] || 0) + 1;
          if (ti.patch) patchLevels[ti.patch] = (patchLevels[ti.patch] || 0) + 1;
          if (ti.py && ti.py !== '*') pyVersions[ti.py] = (pyVersions[ti.py] || 0) + 1;
          if (ti.schema) schemaVersions[ti.schema] = (schemaVersions[ti.schema] || 0) + 1;
      }
  });

  // Meshes
  for (const i in parent.meshes) {
      var item = parent.meshes[i];
      if (item.mtype == 2) {
          var lbl = document.createElement('label');
          lbl.innerHTML = '<input type="checkbox" onclick="selNodesByMesh(this);" value="' + item._id + '"> ' + escHtml(item.name);
          meshList.appendChild(lbl);
      }
  }

  // Device types
  var sortedTypes = Object.keys(deviceTypes).sort();
  var filterSelect = Q('arDeviceFilter');
  filterSelect.innerHTML = '<option value="">All Types</option>';
  sortedTypes.forEach(function(dt) {
      var shortName = dt.replace('MagicCube', '');
      filterSelect.appendChild(new Option(shortName + ' (' + deviceTypes[dt] + ')', dt));
      var lbl = document.createElement('label');
      lbl.innerHTML = '<input type="checkbox" onclick="selNodesByType(this);" value="' + dt + '"> ' + escHtml(shortName) + ' <span class="arNodeInfo">(' + deviceTypes[dt] + ')</span>';
      typeList.appendChild(lbl);
  });

  // Version filter dropdowns
  function populateVersionFilter(selectId, versions, prefix) {
      var sel = Q(selectId);
      var first = sel.options[0].text; // preserve "All X" label
      sel.innerHTML = '';
      sel.appendChild(new Option(first, ''));
      Object.keys(versions).sort().forEach(function(v) {
          sel.appendChild(new Option(prefix + v + ' (' + versions[v] + ')', v));
      });
  }
  populateVersionFilter('arDpFilter', dpVersions, 'dp ');
  populateVersionFilter('arHaFilter', haVersions, 'ha ');
  populateVersionFilter('arPatchFilter', patchLevels, 'p');
  populateVersionFilter('arPyFilter', pyVersions, 'py ');
  populateVersionFilter('arSchemaFilter', schemaVersions, 's');

  // Version checkboxes in sidebar
  function addVersionCheckboxes(container, versions, dataAttr, prefix) {
      if (Object.keys(versions).length === 0) return;
      var hdr = document.createElement('div');
      hdr.style.cssText = 'font-size:10px;font-weight:700;color:var(--fg3);margin-top:6px;text-transform:uppercase;letter-spacing:0.5px;';
      hdr.textContent = prefix;
      container.appendChild(hdr);
      Object.keys(versions).sort().forEach(function(v) {
          var lbl = document.createElement('label');
          lbl.innerHTML = '<input type="checkbox" onclick="selNodesByVersion(this,\'' + dataAttr + '\');" value="' + escHtml(v) + '"> ' + prefix + escHtml(v) + ' <span class="arNodeInfo">(' + versions[v] + ')</span>';
          container.appendChild(lbl);
      });
  }
  addVersionCheckboxes(versionList, dpVersions, 'data-dp', 'DietPi ');
  addVersionCheckboxes(versionList, haVersions, 'data-ha', 'HA ');
  addVersionCheckboxes(versionList, patchLevels, 'data-patch', 'Patch ');
  addVersionCheckboxes(versionList, pyVersions, 'data-py', 'Python ');
  addVersionCheckboxes(versionList, schemaVersions, 'data-schema', 'Schema ');

  updateSelectedCount();
}

function filterAdvancedRun() {
    var query = (Q('arNodeSearch').value || '').toLowerCase();
    var typeFilter = Q('arDeviceFilter').value;
    var dpFilter = Q('arDpFilter').value;
    var haFilter = Q('arHaFilter').value;
    var patchFilter = Q('arPatchFilter').value;
    var pyFilter = Q('arPyFilter').value;
    var schemaFilter = Q('arSchemaFilter').value;
    var nodes = document.querySelectorAll('#arNodeList .arNodeItem');
    nodes.forEach(function(lbl) {
        var name = lbl.getAttribute('data-name') || '';
        var type = lbl.getAttribute('data-type') || '';
        var ip = lbl.getAttribute('data-ip') || '';
        var dp = lbl.getAttribute('data-dp') || '';
        var ha = lbl.getAttribute('data-ha') || '';
        var patch = lbl.getAttribute('data-patch') || '';
        var py = lbl.getAttribute('data-py') || '';
        var schema = lbl.getAttribute('data-schema') || '';
        var matchQ = !query || name.indexOf(query) !== -1 || ip.indexOf(query) !== -1 || type.toLowerCase().indexOf(query) !== -1;
        var matchType = !typeFilter || type === typeFilter;
        var matchDp = !dpFilter || dp === dpFilter;
        var matchHa = !haFilter || ha === haFilter;
        var matchPatch = !patchFilter || patch === patchFilter;
        var matchPy = !pyFilter || py === pyFilter;
        var matchSchema = !schemaFilter || schema === schemaFilter;
        lbl.style.display = (matchQ && matchType && matchDp && matchHa && matchPatch && matchPy && matchSchema) ? '' : 'none';
    });
}

function selNodesByVersion(el, dataAttr) {
    var ver = el.value;
    var checked = el.checked;
    var nodes = document.querySelectorAll('#arNodeList .arNodeItem');
    nodes.forEach(function(lbl) {
        if (lbl.getAttribute(dataAttr) === ver) {
            lbl.querySelector('input[type="checkbox"]').checked = checked;
        }
    });
    syncHiddenCheckboxes();
    updateSelectedCount();
}

function selVisibleNodes(checked) {
    var nodes = document.querySelectorAll('#arNodeList .arNodeItem');
    nodes.forEach(function(lbl) {
        if (lbl.style.display !== 'none') {
            var cb = lbl.querySelector('input[type="checkbox"]');
            if (cb) cb.checked = checked;
        }
    });
    syncHiddenCheckboxes();
    updateSelectedCount();
}

function selNodesByType(el) {
    var dtype = el.value;
    var checked = el.checked;
    var nodes = document.querySelectorAll('#arNodeList .arNodeItem');
    nodes.forEach(function(lbl) {
        if (lbl.getAttribute('data-type') === dtype) {
            lbl.querySelector('input[type="checkbox"]').checked = checked;
        }
    });
    syncHiddenCheckboxes();
    updateSelectedCount();
}

function selNodesByMesh(el) {
    var mid = el.value;
    var checked = el.checked;
    var nodes = document.querySelectorAll('#arNodeList .arNodeItem');
    nodes.forEach(function(lbl) {
        if (lbl.getAttribute('data-mesh') === mid) {
            lbl.querySelector('input[type="checkbox"]').checked = checked;
        }
    });
    syncHiddenCheckboxes();
    updateSelectedCount();
}

function selAllNodes(el) {
    var checked = el.checked;
    var nodes = document.querySelectorAll('#arNodeList input[type="checkbox"]');
    nodes.forEach(function(cb) { cb.checked = checked; });
    syncHiddenCheckboxes();
    updateSelectedCount();
}

function syncHiddenCheckboxes() {
    // Keep hidden mRunTbl in sync for goAdvancedRun()
    var visible = document.querySelectorAll('#arNodeList input[name="runOn[]"]');
    var hidden = Q('mRunTbl').querySelectorAll('input[name="runOn[]"]');
    var checkedIds = {};
    visible.forEach(function(cb) { if (cb.checked) checkedIds[cb.value] = true; });
    hidden.forEach(function(cb) { cb.checked = !!checkedIds[cb.value]; });
}

function updateSelectedCount() {
    var count = document.querySelectorAll('#arNodeList input[name="runOn[]"]:checked').length;
    var total = document.querySelectorAll('#arNodeList input[name="runOn[]"]').length;
    Q('arSelectedCount').textContent = count + ' of ' + total + ' selected';
    syncHiddenCheckboxes();
}

function doOnLoad() {
  redrawScriptTree();
  selectPreviouslySelectedScript();
  updateNodesTable();
  parent.meshserver.send({ 'action': 'plugin', 'plugin': 'innovoscripttask', 'pluginaction': 'loadNodeHistory', 'nodeId': parent.currentNode._id });
  parent.meshserver.send({ 'action': 'plugin', 'plugin': 'innovoscripttask', 'pluginaction': 'loadVariables', 'nodeId': parent.currentNode._id });
}

function selectPreviouslySelectedScript() {
    var sel_item = parent.getstore('_innovoscripttask_sel_item', null)
    if (sel_item != null) {
      var s = document.getElementById(sel_item);
      if (s != null) {
        s.classList.toggle('liselected');
        goScript(s);
      }
    }
    if (sel_item != null) parent.meshserver.send({ 'action': 'plugin', 'plugin': 'innovoscripttask', 'pluginaction': 'loadScriptHistory', 'scriptId': sel_item });
}

function goRun() {
    var selScript = document.querySelectorAll('.liselected');
    if (selScript.length) {
      var scriptId = selScript[0].getAttribute('x-data-id');
      if (scriptId == selScript[0].getAttribute('x-folder-id')) {
          parent.setDialogMode(2, "Oops!", 1, null, 'Please select a script. A folder is currently selected.');
      } else {
          var scriptName = (selScript[0].querySelector('.fname') || {}).textContent || 'script';
          var nodeName = parent.currentNode.name || 'this device';
          parent.setDialogMode(2, "Run Script", 3, function() {
              parent.meshserver.send({ 'action': 'plugin', 'plugin': 'innovoscripttask', 'pluginaction': 'runScript', 'scriptId': scriptId, 'nodes': [ parent.currentNode._id ], 'currentNodeId': parent.currentNode._id });
              openSection('nodeHistory');
              openSection('scriptHistory');
          }, 'Run <b>' + escHtml(scriptName) + '</b> on <b>' + escHtml(nodeName) + '</b>?');
      }
    } else {
        parent.setDialogMode(2, "Oops!", 1, null, 'No script has been selected to run on the machines.');
    }
}

function goEdit() {
    var selScript = document.querySelectorAll('.liselected');
    if (selScript.length && (selScript[0].getAttribute('x-data-id') != selScript[0].getAttribute('x-data-folder'))) {
      var scriptId = selScript[0].getAttribute('x-data-id');
      window.open('/pluginadmin.ashx?pin=innovoscripttask&user=1&edit=1&id=' + scriptId, '_blank');
      window.callback = function(sd) {
          parent.meshserver.send({ 'action': 'plugin', 'plugin': 'innovoscripttask', 'pluginaction': 'editScript', 'scriptId': sd._id, 'scriptType': sd.type, 'scriptName': sd.name, 'scriptContent': sd.content, 'scriptDescription': sd.description, 'scriptCategory': sd.category, 'currentNodeId': parent.currentNode._id });
      };
    } else {
      parent.setDialogMode(2, "Oops!", 1, null, 'No script has been selected to edit.');
    }
}

function goAdvancedRun() {
  var cboxes = document.querySelectorAll('#arNodeList input[name="runOn[]"]');
  var sel = [];
  cboxes.forEach((n) => { if (n.checked) sel.push(n.value); });
  if (sel.length == 0) { parent.setDialogMode(2, "Oops!", 1, null, 'No machines have been selected.'); return; }
  var selScript = document.querySelectorAll('.liselected');
  if (selScript.length) {
    var scriptId = selScript[0].getAttribute('x-data-id');
    var sWin = window.open('/pluginadmin.ashx?pin=innovoscripttask&user=1&schedule=1', 'schedule', "width=800,height=600");
    sWin.scriptId = scriptId;
    sWin.nodes = sel;
    window.schedCallback = function(opts) {
        parent.meshserver.send({
            'action': 'plugin', 'plugin': 'innovoscripttask',
            'pluginaction': 'addScheduledJob', 'scriptId': opts.scriptId,
            'nodes': opts.nodes, 'currentNodeId': parent.currentNode._id, 'schedule': opts
        });
    };
  } else {
    parent.setDialogMode(2, "Oops!", 1, null, 'No script has been selected to run on the machines.');
  }
}

function openSection(sectionId) {
    var section = Q(sectionId);
    if (!section) return;
    var bar = section.previousElementSibling;
    if (bar && !bar.classList.contains('active')) bar.classList.add('active');
    section.style.display = 'block';
    section.style.maxHeight = '300px';
    section.style.overflowY = 'auto';
    resizeIframe();
}

var coll = document.getElementsByClassName("infoBar");
for (var i = 0; i < coll.length; i++) {
  coll[i].addEventListener("click", function() {
    this.classList.toggle("active");
    var content = this.nextElementSibling;
    if (content.style.display === "block") {
      content.style.display = "none";
    } else {
      content.style.display = "block";
    }
    content.style.maxHeight = '300px';
    content.style.overflowY = 'auto';
    resizeIframe();
  });
}

function goDownload() {
  var isSelected = document.querySelectorAll('.liselected');
  if (isSelected.length == 0) return;
  var sel = isSelected[0];
  var id = sel.getAttribute('x-data-id');
  if (id == sel.getAttribute('x-data-folder')) return;
  window.location = '/pluginadmin.ashx?pin=innovoscripttask&user=1&dl='+id;
}
function addScript(name, content, path) {
  var n = name.split('.').pop().toLowerCase();
  if (content.split('\n')[0][0] == '#' && content.split('\n')[0][1] == '!') n = 'bash';
  if (['ps1', 'bat', 'bash'].indexOf(n) !== -1) {
    parent.meshserver.send({ action: 'plugin', plugin: 'innovoscripttask', pluginaction: 'addScript', name: name, content: content, path: path, filetype: n, description: '', category: '' });
  } else {
    parent.setDialogMode(2, "Oops!", 1, null, 'Currently accepted filetypes are .ps1, .bat, and bash scripts.');
  }
}
function redrawScriptTree() {
  var lastpath = null;
  var str = '';
  var indent = 0;
  var folder_id = null;
  str += '<div style="display: block;overflow-y: auto;max-height: 700px;">'
  scriptTree.forEach(function(f) {
    if (f.path != lastpath && f.type == 'folder') {
      indent = (f.path.match(/\//g) || []).length + 1;
      var name = f.path.match(/[^\/]+$/);
      folder_id = f._id;
      str += '<div draggable="true" x-data-path="' + f.path + '" x-data-id="' + f._id + '" x-data-folder="' + folder_id + '" style="padding-left: ' + (indent * 16) + 'px;" class="lifolder" onclick="toggleCollapse(this);"><svg class="folder-icon" viewBox="0 0 16 16"><path d="M.54 3.87.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3H13.5a2 2 0 0 1 2 2v.09A1.98 1.98 0 0 0 15 5h-1a1 1 0 0 0-1 1v.5a.5.5 0 0 1-1 0V6a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.5a.5.5 0 0 1 1 0V13a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V5a2 2 0 0 1 .367-1.13z"/></svg><span class="fname">' + name + '</span></div>';
      lastpath = f.path;
      indent += 1;
    }
    if (f.type != 'folder') {
        var catBadge = (f.category) ? ' <span class="catBadge" data-cat="' + escHtml(f.category) + '">' + escHtml(f.category) + '</span>' : '';
        var descTitle = (f.description) ? ' title="' + escHtml(f.description) + '"' : '';
        var descLine = (f.description) ? '<div class="scriptDesc" style="padding-left: ' + (indent * 16 + 24) + 'px;">' + escHtml(f.description) + '</div>' : '';
        str += '<div id="' + f._id + '" draggable="true" x-data-path="' + f.path + '" x-data-id="' + f._id + '" x-data-folder="' + folder_id + '" x-data-category="' + escHtml(f.category || '') + '" x-data-description="' + escHtml(f.description || '') + '" style="padding-left: ' + (indent * 16) + 'px;" class="liscript"' + descTitle + ' onclick="goScript(this);"><svg class="script-icon" viewBox="0 0 16 16"><path d="M5.5 7a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1zM5 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0 2a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5"/><path d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5zm0 1v2A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/></svg><span class="fname">' + f.name + '</span> <span class="ftype">' + f.filetype + '</span>' + catBadge + '</div>' + descLine;
    }
  });
  str += '</div>';
  document.getElementById('scriptTreeContent').innerHTML = str;
  var liScripts = document.querySelectorAll('.liscript');
  var liFolders = document.querySelectorAll('.lifolder');
  liScripts.forEach(function(el) {
    el.addEventListener('mousedown', function() { elementDragged = true; });
    el.addEventListener('mouseup', function() { elementDragged = false; });
    el.addEventListener('dragstart', function(evt) { evt.dataTransfer.setData('text/plain', evt.target.getAttribute('x-data-id')); });
  });
  liFolders.forEach(function(el) {
    el.addEventListener('drop', dropMove);
    el.addEventListener('dragover', function(e) { e.preventDefault(); });
    el.addEventListener('mousedown', function() { elementDragged = true; });
    el.addEventListener('mouseup', function() { elementDragged = false; });
    el.addEventListener('dragstart', function(evt) { evt.dataTransfer.setData('text/plain', evt.target.getAttribute('x-data-id')); });
  });
