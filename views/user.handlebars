  function toggleCollapse(el) {
    var xdf = el.getAttribute('x-data-path');
    var folderEls = document.querySelectorAll('.lifolder, .liscript, .scriptDesc');
    var showHide = null;
    folderEls.forEach(function(e){
      if (e === el) return;
      var ePath = e.getAttribute('x-data-path') || e.previousElementSibling && e.previousElementSibling.getAttribute && e.previousElementSibling.getAttribute('x-data-path');
      if (ePath && ePath.indexOf(xdf) !== -1) {
        if (showHide === null) showHide = (e.style.display == 'none') ? '' : 'none';
        e.style.display = showHide;
      }
    });
